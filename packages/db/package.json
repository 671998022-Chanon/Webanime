{
  "name": "@nexus/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:verify": "drizzle-kit verify",
    "db:seed": "tsx tooling/scripts/seed.ts",
    "db:seed:catalog": "tsx tooling/scripts/seed-catalog.ts",
    "db:seed:admin": "tsx tooling/scripts/seed-admin.ts",
    "db:seed:anime": "tsx tooling/scripts/seed-anime.ts",
    "db:reset": "drizzle-kit drop && drizzle-kit generate && drizzle-kit migrate && pnpm db:seed",
    "clean": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.38.4"
  },
  "devDependencies": {
    "@nexus/config-eslint": "workspace:*",
    "@nexus/config-typescript": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.21.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
