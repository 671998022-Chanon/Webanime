{
  "name": "@nexus/ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens/index.css",
    "./tokens/index.css": "./src/tokens/index.css",
    "./button": "./src/primitives/button.tsx",
