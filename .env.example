# Environment template for Nexus Anime.
# Copy to apps/web/.env.local and fill in the values.
# DO NOT commit .env.local — it is gitignored.

# --- Database (Neon) ---
# Connection string for the Postgres database used by @nexus/db (Drizzle).
DATABASE_URL=

# --- Cache (Upstash Redis) ---
# REST URL and token for the Redis instance used by @nexus/cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Auth (Auth.js v5) ---
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=
# OAuth provider credentials (enable as needed)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Payments (Stripe) — milestone S5+ ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Video (Cloudflare Stream) — milestone S6+ ---
CLOUDFLARE_STREAM_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
